PORT=3002

# LLM gateway URL. The Anthropic SDK appends "/v1/messages" to this base.
# Set LLM_API_KEY to talk directly to the upstream provider (e.g. a real
# Anthropic key); leave it unset to use the APIM/Bijira client-credentials
# token below as the api key (the gateway proxies and injects the real
# upstream key).
LLM_BASE_URL=https://localhost:8243/anthropic-llm-proxy
MODEL=claude-opus-4-7
# LLM_API_KEY=sk-ant-...

# Services
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your-org-name>
CORS_ORIGIN=http://localhost:5173

# Set to "true" to enforce Asgardeo JWT verification on POST /chat. Leave
# unset/false when running behind a gateway (e.g. WSO2 Choreo) that handles
# auth. ASGARDEO_BASE_URL is only required when AUTH_ENABLED=true.
AUTH_ENABLED=false

# WSO2 APIM/Bijira — client credentials for MCP gateway. Required only when
# the MCP servers sit behind a gateway that validates this token, or when
# LLM_API_KEY is unset (then this token doubles as the LLM bearer). Leave
# APIM_TOKEN_URL unset to skip the startup token fetch entirely — MCP calls
# will then be made without an Authorization header.
APIM_CONSUMER_KEY=<consumer-key>
APIM_CONSUMER_SECRET=<consumer-secret>
APIM_TOKEN_URL=https://localhost:9443/oauth2/token

# MCP servers via APIM gateway
MCP_SERVERS=[{"name":"property-search","url":"https://localhost:8243/property-search/1.0.0/mcp"},{"name":"insurance","url":"https://localhost:8243/insurance/1.0.0/mcp"}]
